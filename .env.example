# Copy to `.env` and fill in. Never commit the populated file.

# --- Phoenix --------------------------------------------------------------
# Reachable URL of your Phoenix instance (Phoenix Cloud, self-hosted, or `phoenix serve`).
PHOENIX_BASE_URL=http://localhost:6006
# Phoenix API key. Omit if running an unauthenticated local instance.
PHOENIX_API_KEY=

# --- Google AI ------------------------------------------------------------
# Used by the Diagnoser (gemini-3.1-pro-preview) and the LLM-as-Judge evaluators
# (gemini-3-flash-preview). Get one from https://aistudio.google.com/.
GOOGLE_API_KEY=

# --- Nengok runtime -------------------------------------------------------
# Phoenix project identifier the SDK should watch.
NENGOK_PROJECT=travel-planner-agent
# Where verified fixes are written.
NENGOK_ARTIFACTS_DIR=./artifacts
# Local SQLite state file for cluster lifecycle and span deduplication.
# Default backend; the file path applies when DATABASE_URL is unset.
NENGOK_STATE_DB=./.nengok/state.db
# Override the backend to Postgres or MySQL. Wins over NENGOK_STATE_DB.
# See docs/configuration.md for the supported dialect matrix.
#DATABASE_URL=postgresql+psycopg://nengok:secret@db.internal/nengok
#DATABASE_URL=mysql+pymysql://nengok:secret@db.internal/nengok
# Internal test networks only; logs a WARNING and skips the TLS rewrite.
#NENGOK_DATABASE_ALLOW_PLAINTEXT=0
# Postgres-only: confine every Nengok table to the named schema.
#NENGOK_DATABASE_SCHEMA=nengok
# Dashboard port (default 8765).
NENGOK_DASHBOARD_PORT=8765

# --- Model overrides ------------------------------------------------------
# SDK defaults live in nengok/config.py; sample-agent defaults live in
# sample_agent/agent.py and sample_agent/qa_agent/agent.py. Uncomment to
# swap models without touching source or ~/.nengok/config.toml.
#NENGOK_DIAGNOSER_MODEL=gemini-3.1-pro-preview
#NENGOK_JUDGE_MODEL=gemini-3-flash-preview
#SAMPLE_AGENT_MODEL=gemini-2.5-flash
#QA_AGENT_MODEL=gemini-2.5-flash
